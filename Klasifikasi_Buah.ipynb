        "history_cnn = train_model(\n",
        "    model=model_cnn,\n",
        "    train_loader=train_loader,\n",
        "    val_loader=val_loader,\n",
        "    epochs=EPOCHS,\n",
        "    lr=LR_CNN\n",
        ")\n",
        "\n",
        "print(\"\\n--- MELATIH MODEL MOBILENETV2 ---\")\n",
        "history_mobilenet = train_model(\n",
        "    model=model_mobilenet,\n",
        "    train_loader=train_loader,\n",
        "    val_loader=val_loader,\n",
        "    epochs=EPOCHS,\n",
        "    lr=LR_MOBILENET\n",
        ")"
      ],
